{
  "name": "@jvseen/dynamo-react-native",
  "version": "0.0.2",
  "description": "Dynamic forms for React Native - Dynamo Forms",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm exec tsup",
    "dev": "pnpm exec tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@jvseen/dynamo-core": "workspace:*",
    "@hookform/resolvers": "^3.3.0",
    "date-fns": "^3.6.0",
    "react-hook-form": "^7.53.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "@react-native-community/datetimepicker": ">=7.0.0",
    "expo-image-picker": ">=15.0.0",
    "expo-location": ">=15.0.0",
    "react-native-element-dropdown": ">=2.0.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-native": "^0.76.0",
    "@react-native-community/datetimepicker": "^7.0.0",
    "expo-image-picker": "^15.0.0",
    "expo-location": "^15.0.0",
    "react-native-element-dropdown": "^2.0.0",
    "react-native-safe-area-context": "^4.10.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jvse/dynamo-forms.git",
    "directory": "packages/react-native"
  }
}
