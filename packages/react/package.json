{
  "name": "@jvseen/dynamo-react",
  "version": "0.0.1",
  "description": "Dynamic forms for React (web) - Dynamo Forms",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:css": "pnpm exec tailwindcss -i src/styles/index.css -o dist/styles.css --minify",
    "build": "pnpm exec tsup && pnpm run build:css",
    "dev:css": "pnpm exec tailwindcss -i src/styles/index.css -o dist/styles.css --watch",
    "dev": "pnpm exec tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@hookform/resolvers": "^3.3.0",
    "@jvseen/dynamo-core": "workspace:*",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.460.0",
    "react-day-picker": "^9.4.0",
    "react-hook-form": "^7.53.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jvse/dynamo-forms.git",
    "directory": "packages/react"
  }
}
